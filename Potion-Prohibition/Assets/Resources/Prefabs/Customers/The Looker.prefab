  textComponet: {fileID: 1032148383272698172}
  linesIntro1:
  - 
  - ...
  - (They stare in silence. Not the talkative bunch it seems.)
  linesIntro: []
  linesIntro2:
  - 
  - ...
  - ... (It just blinks at you.)
  linesIntro3:
  - 
  - '... '
  - (It blinks at you in greeting. You blink back.)
  - (You wonder if it would be rude to ask how it drinks its potion?)
  linesPasstime:
  - 
  - ...
  - ... (It looks expectantly at you, as if you should know what it wants.)
  linesRight:
  - ...
  - "(In unison, the eyes blink slowly, as if saying \u2018thank you.\u2019)"
  linesWrong:
  - ...
  - "(Its \u2026 eyes narrow onto you.)"
  - (For a creature with no facial structure, it sure does a good job of looking
    angry.)
  linesEnd:
  - '... '
  - "(it doesn\u2019t say anything as it hovers away.)"
  textSpeed: 0.05
