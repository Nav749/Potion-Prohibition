  m_Script: {fileID: 11500000, guid: 60c93280562adf948b0d55e27c01ca2e, type: 3}
  m_Name: Dialogue7
  m_EditorClassIdentifier: 
  combo: 52
  dialogue:
  - "It looks like Whiskers has returned here once again, after proclaiming he wouldn\u2019t."
  - "I would prefer if more \u2018dignified\u2019 creatures would go elsewheres to
    find their potions. This place is not for them. "
  - 'I fear that Whiskers is not only here for potions. '
  - 'Hm, perhaps you are right. I shall send some of my men to investigate him. '
  - wait.
  - '(He does not seem to be paying attention any longer) '
  - "This is not my problem. I have a Bunny to annoy. If you excuse me\u2026 "
  names:
  - Spinx
  - Jupiter Fox
